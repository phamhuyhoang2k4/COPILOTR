{
    "name": "XMRig Worker Container",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {}
    },
    "postCreateCommand": "chmod +x .devcontainer/setup_xmrig.sh && .devcontainer/setup_xmrig.sh",
    "customizations": {
        "vscode": {
            "extensions": []
        }
    },
    "runArgs": [
        "--name",
        "xmrig_dev_container"
    ],
    // Tắt chế độ tự động xóa container khi thoát để nó chạy ngầm (nếu muốn)
    "shutdownAction": "none"
}
